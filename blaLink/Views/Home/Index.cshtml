@model IEnumerable<blaLink.Models.ShortLink>

@{
    ViewData["Title"] = "List of Links";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>All Shortened Links</h2>
        <a asp-controller="Links" asp-action="Create" class="btn btn-success">+ Create New</a>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Short Code</th>
                        <th>Original Link</th>
                        <th class="text-center">Click Count</th>
                        <th>Created Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <a href="/@item.ShortCode" target="_blank" class="fw-bold text-primary">
                                    /@item.ShortCode
                                </a>
                            </td>
                            <td class="text-truncate" style="max-width: 300px;">
                                <small>@item.OriginalUrl</small>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-info text-dark">@item.ClickCount</span>
                            </td>
                            <td>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>